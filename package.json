{
  "name": "note",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "cfbuild": "git fetch --unshallow && astro build",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "docs:lint": "markdownlint-cli2 \"README.md\" \"DOCS_STYLE.md\" \"src/content/docs/**/*.md\"",
    "docs:spell": "cspell \"README.md\" \"DOCS_STYLE.md\" \"src/content/docs/**/*.md\" && textlint \"README.md\" \"DOCS_STYLE.md\" \"src/content/docs/**/*.md\"",
    "docs:links": "npm run build && linkinator dist --recurse --clean-urls --check-fragments --config linkinator.config.json",
    "docs:check": "npm run docs:lint && npm run docs:spell && npm run docs:links && npm run build"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.0",
    "@astrojs/starlight": "^0.39.2",
    "astro": "^6.4.2",
    "astro-mermaid": "2.0.1",
    "mermaid": "^11.12.2",
    "rehype-mathjax": "^7.1.0",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "cspell": "10.0.0",
    "echarts": "^6.0.0",
    "linkinator": "7.6.1",
    "markdownlint-cli2": "0.22.1",
    "textlint": "15.7.1",
    "textlint-rule-preset-zh-technical-writing": "0.0.3",
    "unist-util-visit": "^5.0.0"
  }
}
